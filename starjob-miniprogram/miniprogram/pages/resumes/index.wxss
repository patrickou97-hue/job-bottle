.page-header {
  padding: 18rpx 0 34rpx;
  border-bottom: 1rpx solid var(--color-line);
}

.state-panel {
  margin-top: 56rpx;
  padding: 54rpx 0;
  border-top: 1rpx solid var(--color-line);
  border-bottom: 1rpx solid var(--color-line);
  text-align: center;
}

.state-title,
.state-copy {
  display: block;
}

.state-title {
  font-size: 31rpx;
  font-weight: 660;
}

.state-copy {
  max-width: 560rpx;
  margin: 14rpx auto 0;
  color: var(--color-ink-soft);
  font-size: 25rpx;
}

.state-action {
  width: 240rpx;
  margin: 30rpx auto 0;
}

.resume-list {
  margin-top: 22rpx;
}

.resume-row {
  display: flex;
  align-items: flex-start;
  padding: 34rpx 0;
  border-bottom: 1rpx solid var(--color-line);
}

.resume-mark {
  flex: 0 0 64rpx;
  height: 64rpx;
  border: 1rpx solid rgba(82, 121, 169, 0.28);
  border-radius: 50%;
  color: var(--color-blue);
  font-size: 22rpx;
  line-height: 64rpx;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.resume-content {
  min-width: 0;
  margin-left: 24rpx;
}

.resume-title,
.resume-role,
.resume-updated {
  display: block;
}

.resume-title {
  font-size: 31rpx;
  font-weight: 660;
}

.resume-role {
  margin-top: 8rpx;
  color: var(--color-ink-soft);
  font-size: 25rpx;
}

.resume-updated {
  margin-top: 14rpx;
  color: var(--color-muted);
  font-size: 22rpx;
}

.resume-skeleton {
  padding: 34rpx 0;
  border-bottom: 1rpx solid var(--color-line);
}

.skeleton-title {
  width: 58%;
  height: 32rpx;
}

.skeleton-meta {
  width: 38%;
  margin-top: 20rpx;
}
